datasource db {
    provider = "postgresql"
    url      = env("DIRECT_URL")
}

generator client {
    provider = "prisma-client-js"
}

enum Role {
    super_admin
    admin
    secretaria
    professor
    aluno
}

enum AttendanceStatus {
    presente
    falta
    abono
}

enum ModalityType {
    presencial
    online
}

enum ExcuseType {
    merito
    eventualidade
    medico
}

enum ExcuseStatus {
    vigente
    agendado
    encerrado
}

enum DifficultyTier {
    facil
    medio
    dificil
}

model Tenant {
    id           String   @id @default(uuid()) @db.Uuid
    name         String
    slug         String   @unique
    primaryColor String   @default("#10b981") @map("primary_color")
    secondaryColor String? @map("secondary_color")
    logoUrl      String?  @map("logo_url")
    loginUrl     String?  @map("login_url")
    createdAt    DateTime @default(now()) @map("created_at")
    updatedAt    DateTime @updatedAt @map("updated_at")

    users             User[]
    subjects          Subject[]
    modalities        Modality[]
    classes           Class[]
    attendanceRecords AttendanceRecord[]
    attendanceExcuses AttendanceExcuse[]
    exams             Exam[]
    studentResponses  StudentResponse[]
    presenceWindows   PresenceWindow[]
    scheduledClasses  ScheduledClass[]
    triReferences     TriReference[]
    examGrades        ExamGrade[]
    allowedReportTemplates String[] @default(["ENEM", "UERJ", "ENEM_PARCIAL", "DISCURSIVO"]) @map("allowed_report_templates")

    @@map("tenants")
}

model User {
    id                 String   @id @default(uuid()) @db.Uuid
    tenantId           String   @map("tenant_id") @db.Uuid
    name               String
    email              String
    passwordHash       String   @map("password_hash")
    role               Role
    registrationNumber String   @map("registration_number")
    mustChangePassword Boolean  @default(true) @map("must_change_password")
    department         String?  @map("department")
    classId            String?  @map("class_id") @db.Uuid
    createdAt          DateTime @default(now()) @map("created_at")
    updatedAt          DateTime @updatedAt @map("updated_at")

    tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    class             Class?             @relation(fields: [classId], references: [id], onDelete: SetNull)
    attendanceRecords AttendanceRecord[]
    attendanceExcuses AttendanceExcuse[]
    studentResponses  StudentResponse[]
    examGrades        ExamGrade[]
    examSessions      ExamSession[]

    @@unique([tenantId, email])
    @@unique([tenantId, registrationNumber])
    @@index([tenantId])
    @@map("users")
}

model Subject {
    id                  String   @id @default(uuid()) @db.Uuid
    tenantId            String   @map("tenant_id") @db.Uuid
    name                String
    isAttendanceSubject Boolean  @default(true) @map("is_attendance_subject")
    createdAt           DateTime @default(now()) @map("created_at")

    tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    excuseSubjects    ExcuseSubject[]
    examQuestions     ExamQuestion[]
    modalitySubjects  ModalitySubject[]
    presenceWindows   PresenceWindow[]
    scheduledClasses  ScheduledClass[]

    @@unique([tenantId, name])
    @@map("subjects")
}

// 1. MODALIDADE (O Combo de Cursos: ex: "Especificas + Exatas", "Semipresencial")
model Modality {
    id        String   @id @default(uuid()) @db.Uuid
    tenantId  String   @map("tenant_id") @db.Uuid
    name      String
    createdAt DateTime @default(now()) @map("created_at")

    tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    classes          Class[]
    modalitySubjects ModalitySubject[]

    @@unique([tenantId, name])
    @@map("modalities")
}

// 2. TURMA (O agrupamento real de pessoas dentro de um combo: ex: "Med A", "Med B")
model Class {
    id         String   @id @default(uuid()) @db.Uuid
    tenantId   String   @map("tenant_id") @db.Uuid
    modalityId String   @map("modality_id") @db.Uuid
    name       String
    createdAt  DateTime @default(now()) @map("created_at")

    tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    modality          Modality           @relation(fields: [modalityId], references: [id], onDelete: Cascade)
    presenceWindows   PresenceWindow[]
    scheduledClasses  ScheduledClass[]
    users             User[]

    @@unique([tenantId, modalityId, name])
    @@map("classes")
}

// 3. TABELA PIVÔ: Vincula as matérias que cada modalidade/combo oferece
model ModalitySubject {
    modalityId String @map("modality_id") @db.Uuid
    subjectId  String @map("subject_id") @db.Uuid

    modality Modality @relation(fields: [modalityId], references: [id], onDelete: Cascade)
    subject  Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

    @@id([modalityId, subjectId])
    @@map("modality_subjects")
}

model AttendanceRecord {
    id               String           @id @default(uuid()) @db.Uuid
    tenantId         String           @map("tenant_id") @db.Uuid
    scheduledClassId String           @map("scheduled_class_id") @db.Uuid
    studentId        String           @map("student_id") @db.Uuid
    status           AttendanceStatus
    modality         ModalityType
    createdAt        DateTime         @default(now()) @map("created_at")

    tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    scheduledClass ScheduledClass @relation(fields: [scheduledClassId], references: [id], onDelete: Cascade)
    student        User           @relation(fields: [studentId], references: [id], onDelete: Cascade)

    @@index([tenantId, scheduledClassId])
    @@unique([studentId, scheduledClassId])
    @@map("attendance_records")
}

model AttendanceExcuse {
    id        String       @id @default(uuid()) @db.Uuid
    tenantId  String       @map("tenant_id") @db.Uuid
    studentId String       @map("student_id") @db.Uuid
    type      ExcuseType
    reason    String
    startDate DateTime     @map("start_date") @db.Date
    endDate   DateTime     @map("end_date") @db.Date
    status    ExcuseStatus
    createdAt DateTime     @default(now()) @map("created_at")

    tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    student        User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
    excuseSubjects ExcuseSubject[]

    @@map("attendance_excuses")
}

model ExcuseSubject {
    excuseId  String @map("excuse_id") @db.Uuid
    subjectId String @map("subject_id") @db.Uuid

    excuse  AttendanceExcuse @relation(fields: [excuseId], references: [id], onDelete: Cascade)
    subject Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)

    @@id([excuseId, subjectId])
    @@map("excuse_subjects")
}

model Exam {
    id             String   @id @default(uuid()) @db.Uuid
    tenantId       String   @map("tenant_id") @db.Uuid
    title          String
    date           DateTime @db.Date
    totalQuestions Int      @default(60) @map("total_questions")
    type           String   @default("enem")
    isPublished    Boolean  @default(false) @map("is_published")
    isEnemFull     Boolean  @default(false) @map("is_enem_full")
    windowStart    DateTime @default(now()) @map("window_start")
    windowEnd      DateTime @default(now()) @map("window_end")
    windowStart2   DateTime? @map("window_start_2")
    windowEnd2     DateTime? @map("window_end_2")
    createdAt      DateTime @default(now()) @map("created_at")

    tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    examQuestions    ExamQuestion[]
    studentResponses StudentResponse[]
    examGrades       ExamGrade[]
    examSessions     ExamSession[]

    @@map("exams")
}

model ExamSession {
    id        String   @id @default(uuid()) @db.Uuid
    tenantId  String   @map("tenant_id") @db.Uuid
    examId    String   @map("exam_id") @db.Uuid
    studentId String   @map("student_id") @db.Uuid
    dayNumber Int      @map("day_number") @default(1)
    submitted Boolean  @default(false)
    createdAt DateTime @default(now()) @map("created_at")

    exam    Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
    student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

    @@unique([examId, studentId, dayNumber])
    @@map("exam_sessions")
}

model ExamQuestion {
    id                 String         @id @default(uuid()) @db.Uuid
    examId             String         @map("exam_id") @db.Uuid
    questionNumber     Int            @map("question_number")
    correctAlternative String         @map("correct_alternative") @db.Char(1)
    difficultyTier     DifficultyTier @map("difficulty_tier")
    isAnnulled         Boolean        @default(false) @map("is_annulled")
    subjectId          String         @map("subject_id") @db.Uuid
    theme              String?
    language           String         @default("none")

    exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
    subject Subject @relation(fields: [subjectId], references: [id], onDelete: Restrict)

    @@unique([examId, questionNumber, language])
    @@map("exam_questions")
}

model StudentResponse {
    id                String   @id @default(uuid()) @db.Uuid
    tenantId          String   @map("tenant_id") @db.Uuid
    studentId         String   @map("student_id") @db.Uuid
    examId            String   @map("exam_id") @db.Uuid
    questionNumber    Int      @map("question_number")
    chosenAlternative String?  @map("chosen_alternative") @db.Char(1)
    isCorrect         Boolean  @default(false) @map("is_correct")
    importedViaRemark Boolean  @default(false) @map("imported_via_remark")
    language          String   @default("none")
    createdAt         DateTime @default(now()) @map("created_at")

    tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
    exam    Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

    @@unique([studentId, examId, questionNumber])
    @@index([studentId, examId])
    @@map("student_responses")
}

model PresenceWindow {
    id         String   @id @default(uuid()) @db.Uuid
    tenantId   String   @map("tenant_id") @db.Uuid
    classId    String   @map("class_id") @db.Uuid
    subjectId  String   @map("subject_id") @db.Uuid
    dayOfWeek  Int      @map("day_of_week") // 0 = Domingo, 1 = Segunda, etc.
    startTime  String   @map("start_time") // formato HH:mm
    endTime    String   @map("end_time") // formato HH:mm
    showCard   Boolean  @default(false) @map("show_card")
    createdAt  DateTime @default(now()) @map("created_at")

    tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
    subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
    scheduledClasses ScheduledClass[]

    @@map("presence_windows")
}

model ScheduledClass {
    id               String          @id @default(uuid()) @db.Uuid
    tenantId         String          @map("tenant_id") @db.Uuid
    classId          String          @map("class_id") @db.Uuid
    subjectId        String          @map("subject_id") @db.Uuid
    presenceWindowId String?         @map("presence_window_id") @db.Uuid
    date             DateTime        @db.Date
    startTime        String          @map("start_time")
    endTime          String          @map("end_time")
    showCard         Boolean         @default(false) @map("show_card")
    isCanceled       Boolean         @default(false) @map("is_canceled")
    createdAt        DateTime        @default(now()) @map("created_at")

    tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    class            Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
    subject          Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
    presenceWindow   PresenceWindow? @relation(fields: [presenceWindowId], references: [id], onDelete: SetNull)
    attendanceRecords AttendanceRecord[]

    @@index([tenantId, classId, date])
    @@map("scheduled_classes")
}

model TriReference {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  year      String   // ex: "2025"
  subject   String   // ex: "MATEMATICA", "NATUREZAS", "HUMANAS", "LINGUAGENS"
  tier      String   // ex: "principal", "facil", "dificil"
  acertos   Int
  linInf    Float    @map("lin_inf")
  maxima    Float    @map("maxima")
  minima    Float    @map("minima")
  createdAt DateTime @default(now()) @map("created_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, year, subject, tier, acertos])
  @@index([tenantId, year, subject, tier])
  @@map("tri_references")
}

model ExamGrade {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  examId    String   @map("exam_id") @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  subject   String   // Ex: "MATEMATICA", "NATUREZAS", "HUMANAS", "LINGUAGENS" ou "UERJ_EQ"
  acertos   Int
  scoreTri  Float    @map("score_tri")  // Nota final calculada
  tierUsed  String   @map("tier_used")  // "facil", "principal", "dificil" ou "regular"
  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exam    Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId, subject])
  @@map("exam_grades")
}
